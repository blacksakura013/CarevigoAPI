# ===============================
# 🌐 SERVER CONFIG
# ===============================
PORT=8080
NODE_ENV=development

# ===============================
# 🗄️ DATABASE (MongoDB Atlas)
# ===============================
MONGO_URI=${MONGO_URI}

# ===============================
# 🔐 JWT AUTH
# ===============================
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRE=1d

JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_REFRESH_EXPIRE=7d

# ===============================
# 🔢 OTP CONFIG
# ===============================
OTP_EXPIRE=300
OTP_MAX_ATTEMPT=5
OTP_LENGTH=6

# ===============================
# ⚡ REDIS
# ===============================
REDIS_URL=disabled
# ===============================
# 📩 EMAIL SERVICE
# ===============================
EMAIL_SERVICE=gmail
EMAIL_USER=${EMAIL_USER}
EMAIL_PASS=${EMAIL_PASS}

EMAIL_FROM=Carevigo <no-reply@carevigo.com>

# ===============================
# 🚫 RATE LIMIT
# ===============================
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=5

# ===============================
# 🛡️ SECURITY
# ===============================
BCRYPT_SALT=10

# ===============================
# 🌍 FRONTEND
# ===============================
CLIENT_URL=http://localhost:3000

LINE_CHANNEL_ACCESS_ID=${LINE_CHANNEL_ACCESS_ID}
LINE_CHANNEL_SECRET=${LINE_CHANNEL_SECRET}
